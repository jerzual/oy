{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/",
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "esModuleInterop": true,
    "target": "es2017",
    "allowSyntheticDefaultImports": true,
    "lib": ["es2017", "dom"],
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "typeRoots": ["node_modules/@types/"]
  },
  "files": ["src/server.tsx"],
  "include": ["src/**/*"],
	"exclude": [
		"node_modules"
	]
}
