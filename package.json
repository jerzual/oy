{
   "name": "@jerzual/uoy",
   "version": "1.0.0",
   "description": "a rogue platformer",
   "main": "www/server.js",
   "scripts": {
      "compile:client": "tsc",
      "compile:server": "tsc -p tsconfig.server.json",
      "build": "npm run build:client && npm run build:server",
      "fuse": "fuse",
      "build:server": "cross-env NODE_ENV=production webpack -p --config webpack.server.config.ts",
      "test": "jest",
      "test:watch": "jest --watchAll",
      "test:ci": "jest --runInBand --coverage",
      "watch": "webpack-dev-server --progress --hot --colors --mode development",
      "watch:prod": "cross-env NODE_ENV=production webpack-dev-server --progress --colors --content-base dist/www --mode production",
      "watch:server": "nodemon --watch 'app/**/*.ts' --ignore 'app/**/*.spec.ts' --exec ts-node app/server.ts",
      "lint": "tslint --force --project .",
      "start": "ts-node src/index.ts",
      "typedoc": "typedoc --out ./reports/documentation/ --verbose --exclude \"**/*.{spec.ts,scss}\" --includeDeclarations typings/ ./app/main.ts ",
      "webdriver-start": "webdriver-manager start &",
      "webdriver-update": "webdriver-manager update",
      "protractor": "protractor",
      "stats": "webpack --json > stats.json",
      "e2e": "tsc protractor.conf.ts --outDir . --module CommonJS && protractor",
      "e2e:ci": "tsc protractor.conf.ts --outDir . && protractor --capabilities.chromeOptions.args=--headless --capabilities.chromeOptions.args=--no-sandbox",
      "prf": "artillery run prf/scenario.yml"
   },
   "keywords": [
      "platformer",
      "rogue-like",
      "pixi"
   ],
   "repository": {
      "type": "git",
      "url": "https://github.com/jerzual/oy.git"
   },
   "bugs": {
      "url": "https://github.com/jerzual/oy/issues"
   },
   "author": "jibhaine",
   "license": "MIT",
   "dependencies": {
      "canvas": "^2.6.0",
      "express": "^4.17.1",
      "injection-js": "^2.2.2",
      "jsdom": "^15.2.0",
      "matter-js": "^0.14.2",
      "mysql": "^2.14.1",
      "pixi-layers": "^0.1.6",
      "pixi-lights": "^2.0.3",
      "pixi.js": "^4.5.0",
      "preact": "^10.0.4",
      "preact-render-to-string": "^5.1.0",
      "preact-router": "^3.1.0",
      "pug": "^2.0.4",
      "reactive-state": "^3.4.0",
      "reflect-metadata": "^0.1.13",
      "rot-js": "^2.1.1",
      "rxjs": "^6.5.3",
      "schemapack": "^1.4.2",
      "seedrandom": "^3.0.5",
      "socket.io": "^2.3.0",
      "socket.io-client": "^2.3.0",
      "typeorm": "^0.2.20",
      "uuid": "^3.3.3",
      "webrtc-adapter": "^7.3.0"
   },
   "devDependencies": {
      "@types/artillery": "^1.6.2",
      "@types/chance": "^1.0.7",
      "@types/cucumber": "^4.0.7",
      "@types/express": "^4.17.1",
      "@types/faker": "^4.1.7",
      "@types/jest": "^24.0.21",
      "@types/matter-js": "^0.10.3",
      "@types/node": "^12.12.3",
      "@types/pug": "^2.0.4",
      "@types/seedrandom": "^2.4.28",
      "@types/selenium-webdriver": "^3.0.16",
      "@types/socket.io": "^2.1.4",
      "@types/socket.io-client": "^1.4.32",
      "@types/supertest": "^2.0.8",
      "artillery": "^1.6.0-29",
      "autoprefixer": "^9.7.0",
      "babel-jest": "^24.9.0",
      "cross-env": "^5.2.1",
      "cucumber": "^6.0.3",
      "cucumber-html-reporter": "^5.0.2",
      "faker": "^4.1.0",
      "fuse-box": "^4.0.0-next.147",
      "fuse-box-typechecker": "^3.0.0-next.29",
      "identity-obj-proxy": "^3.0.0",
      "jest": "^24.9.0",
      "jest-html-reporter": "^2.6.2",
      "log4js": "^5.3.0",
      "mkdirp": "^0.5.1",
      "node-sass": "^4.13.0",
      "postcss-modules": "^1.4.1",
      "protractor": "^5.4.2",
      "protractor-cucumber-framework": "^6.1.3",
      "supertest": "^4.0.2",
      "ts-jest": "^24.1.0",
      "ts-node": "^8.4.1",
      "tsconfig-paths": "^3.9.0",
      "tslib": "^1.10.0",
      "tslint": "^5.20.0",
      "tslint-config-prettier": "^1.18.0",
      "tslint-react": "^4.1.0",
      "typedoc": "^0.15.0",
      "typescript": "^3.6.4"
   }
}
